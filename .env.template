TELEGRAM_BOT_TOKEN=8734340861:AAHFai4sqkCcOyh7JGzLg5a2VnJmLnZ8ji0
ADMIN_CHAT_ID=661435601

# ── E-mail (Microsoft 365 SMTP) ───────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=buero@rafer.de
SMTP_PASS=SENHA_DO_BUERO_AQUI
